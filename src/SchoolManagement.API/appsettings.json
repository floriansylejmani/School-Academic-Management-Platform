{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=school_management;Username=postgres;Password=postgres"
  },
  "Database": {
    "AutoMigrate": false,
    "SeedDemoData": false
  },
  "Jwt": {
    "Issuer": "SchoolManagement",
    "Audience": "SchoolManagement.Client",
    "SecretKey": "ChangeThisSecretKeyInProduction_AtLeast32Characters!",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "PasswordReset": {
    "TokenExpiryMinutes": 30,
    "FrontendResetUrl": "http://localhost:3000/reset-password"
  },
  "OpenAI": {
    "Enabled": false,
    "ApiKey": "",
    "BaseUrl": "https://api.openai.com/v1/",
    "Model": "gpt-5.4-mini",
    "ReasoningEffort": "low",
    "TimeoutSeconds": 45,
    "MaxEssayCharacters": 12000,
    "UseModeration": false,
    "ModerationModel": "omni-moderation-latest"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{TraceId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Application": "SchoolManagement.API"
    }
  },
  "AllowedHosts": "*"
}
