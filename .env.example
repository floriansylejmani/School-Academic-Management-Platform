ASPNETCORE_ENVIRONMENT=Production

POSTGRES_DB=school_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

API_PORT=5000
FRONTEND_PORT=3000
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_ORIGIN_ALT=http://localhost:3001
FRONTEND_ORIGIN_FALLBACK=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000/api

DATABASE_AUTO_MIGRATE=true
DATABASE_SEED_DEMO_DATA=true
DATABASE_INIT_LOCK_RETRY_DELAY_SECONDS=2
DATABASE_INIT_LOCK_TIMEOUT_SECONDS=60

JWT_ISSUER=SchoolManagement
JWT_AUDIENCE=SchoolManagement.Client
JWT_SECRET_KEY=ChangeMeForDemoOnly_AtLeast32Characters!
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=30
PASSWORD_RESET_FRONTEND_URL=http://localhost:3000/reset-password

OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1/
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_ESSAY_CHARACTERS=12000
OPENAI_USE_MODERATION=false
OPENAI_MODERATION_MODEL=omni-moderation-latest

# Rate Limiting Configuration
RATE_LIMITING_DEFAULT_LIMIT=100
RATE_LIMITING_DEFAULT_WINDOW_SECONDS=60
RATE_LIMITING_AUTH_LIMIT=5
RATE_LIMITING_AUTH_WINDOW_SECONDS=300

# Audit Logging Configuration
AUDIT_LOG_ALL_EVENTS=false
AUDIT_RETENTION_DAYS=90
AUDIT_ENABLE_CLEANUP=true
