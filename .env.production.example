# School Management System - Production Environment Configuration
# Copy this file to .env.production and customize for your deployment

# =============================================================================
# SECURITY CONFIGURATION (CRITICAL - MUST CHANGE)
# =============================================================================

# JWT Configuration - Generate a strong 64-character secret
# Command: openssl rand -base64 64
JWT_SECRET_KEY=CHANGE_ME_GENERATE_64_CHARACTER_SECRET_KEY_HERE
JWT_ISSUER=SchoolManagement
JWT_AUDIENCE=SchoolManagement.Client
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# Database Security - Generate a strong password
# Command: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD_HERE
POSTGRES_USER=school_admin
POSTGRES_DB=school_management_prod

# =============================================================================
# DOMAIN CONFIGURATION (REQUIRED FOR PRODUCTION)
# =============================================================================

# Frontend URLs - Update with your actual domain
FRONTEND_ORIGIN=https://your-school.com
FRONTEND_ORIGIN_ALT=https://www.your-school.com

# API Configuration
NEXT_PUBLIC_API_URL=https://api.your-school.com/api
API_PORT=8080

# Password Reset URL
PASSWORD_RESET_FRONTEND_URL=https://your-school.com/reset-password
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=30

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database Connection
POSTGRES_PORT=5432
DATABASE_AUTO_MIGRATE=false
DATABASE_SEED_DEMO_DATA=false

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Environment
ASPNETCORE_ENVIRONMENT=Production

# Frontend Configuration
FRONTEND_PORT=3000

# =============================================================================
# SECURITY ENHANCEMENTS
# =============================================================================

# Rate Limiting Configuration
RATE_LIMITING_DEFAULT_LIMIT=100
RATE_LIMITING_DEFAULT_WINDOW_SECONDS=60
RATE_LIMITING_AUTH_LIMIT=5
RATE_LIMITING_AUTH_WINDOW_SECONDS=300

# Audit Logging Configuration
AUDIT_LOG_ALL_EVENTS=true
AUDIT_RETENTION_DAYS=90
AUDIT_ENABLE_CLEANUP=true

# =============================================================================
# OPTIONAL FEATURES
# =============================================================================

# AI Features (OpenAI Integration)
OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1/
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_ESSAY_CHARACTERS=12000
OPENAI_USE_MODERATION=false
OPENAI_MODERATION_MODEL=omni-moderation-latest

# =============================================================================
# DEVELOPMENT/DEBUG SETTINGS (PRODUCTION: KEEP DEFAULTS)
# =============================================================================

# Logging and Monitoring
LOG_LEVEL=Information
ENABLE_DETAILED_ERRORS=false
ENABLE_SWAGGER=false

# File Upload Limits
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png

# =============================================================================
# EXTERNAL SERVICES CONFIGURATION
# =============================================================================

# Email Configuration (for password reset)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=noreply@your-school.com
EMAIL_FROM_NAME=School Management System

# =============================================================================
# BACKUP AND MAINTENANCE
# =============================================================================

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/backups

# =============================================================================
# MONITORING AND HEALTH CHECKS
# =============================================================================

# Health Check Configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL_SECONDS=30
HEALTH_CHECK_TIMEOUT_SECONDS=10
HEALTH_CHECK_RETRIES=3

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================

# Connection Pooling
DB_CONNECTION_POOL_SIZE=20
DB_CONNECTION_TIMEOUT_SECONDS=30

# Caching
CACHE_ENABLED=true
CACHE_DEFAULT_EXPIRATION_MINUTES=60
CACHE_MAX_MEMORY_MB=512

# =============================================================================
# COMPLIANCE AND PRIVACY
# =============================================================================

# Data Protection
DATA_PROTECTION_ENABLED=true
DATA_PROTECTION_KEY_RETENTION_DAYS=90
DATA_PROTECTION_CONSENT_COOKIE_DAYS=365

# Privacy Settings
PRIVACY_ANONYMIZE_DATA=true
PRIVACY_DATA_RETENTION_YEARS=7
PRIVITY_EXPORT_ENABLED=true
PRIVACY_DELETE_ENABLED=true

# =============================================================================
# INTEGRATION CONFIGURATION
# =============================================================================

# LDAP/Active Directory (Optional)
LDAP_ENABLED=false
LDAP_SERVER=
LDAP_PORT=389
LDAP_USE_SSL=false
LDAP_BASE_DN=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=

# SSO Configuration (Optional)
SSO_ENABLED=false
SSO_PROVIDER=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=

# =============================================================================
# CUSTOMIZATION
# =============================================================================

# School Information
SCHOOL_NAME=Your School Name
SCHOOL_ADDRESS=123 School Street, City, State 12345
SCHOOL_PHONE=+1-555-123-4567
SCHOOL_EMAIL=info@your-school.com
SCHOOL_WEBSITE=https://your-school.com

# Academic Settings
ACADEMIC_YEAR_START_MONTH=8
ACADEMIC_YEAR_END_MONTH=7
GRADE_SCALE_TYPE=percentage
PASSING_GRADE=60

# =============================================================================
# PRODUCTION SECURITY CHECKLIST
# =============================================================================

# Before deploying to production, ensure you have:
# 1. Generated a strong JWT_SECRET_KEY (64+ characters)
# 2. Generated a strong POSTGRES_PASSWORD
# 3. Set your actual domain in FRONTEND_ORIGIN
# 4. Configured SSL certificates
# 5. Set DATABASE_SEED_DEMO_DATA=false
# 6. Set DATABASE_AUTO_MIGRATE=false (after initial deployment)
# 7. Configured email settings for password reset
# 8. Set up backup strategy
# 9. Configured monitoring and alerting
# 10. Reviewed all security settings

# =============================================================================
# QUICK DEPLOYMENT COMMANDS
# =============================================================================

# Generate secrets:
# JWT_SECRET_KEY=$(openssl rand -base64 64)
# POSTGRES_PASSWORD=$(openssl rand -base64 32)

# Deploy with Docker Compose:
# docker compose -f docker-compose.yml --env-file .env.production up --build -d

# Check deployment:
# curl -k https://your-school.com/health

# View logs:
# docker compose logs -f api
# docker compose logs -f frontend
